{
  "expo": {
    "name": "Tech Orgánico",
    "slug": "tech-organico-mexicano",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F2F1E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "mx.techorganico.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#0F2F1E"
      },
      "package": "mx.techorganico.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-av",
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir acceso a la cámara para la vista 360°."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir acceso a la galería para subir fotos de productos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "techorganico",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "284bb70e-a361-45cd-9157-a88caa44c3c1"
      }
    },
    "owner": "srwaffles-organization"
  }
}
