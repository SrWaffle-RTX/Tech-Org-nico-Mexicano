{
  "expo": {
    "name": "Tech Orgánico",
    "slug": "tech-organico",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E5E3A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "mx.techorganico.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1E5E3A"
      },
      "package": "mx.techorganico.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-av",
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir acceso a la cámara para la vista 360°."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir acceso a la galería para subir fotos de productos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "techorganico"
  }
}
